BeginJS
  // read Neo variable into JS
  var txt = $App.RecData || &quot;&quot;;

  // normalise line breaks then split into lines
  txt = txt.replace(/\r/g, &quot;&quot;);
  var raw = txt.split(&quot;\n&quot;);

  // trim + remove blanks
  var lines = [];
  for (var i = 0; i &lt; raw.length; i++) {
    var s = raw[i].trim();
    if (s !== &quot;&quot;) lines.push(s);
  }

